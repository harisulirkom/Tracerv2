APP_NAME=CDC
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.cdc.example.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cdc
DB_USERNAME=cdc_user
DB_PASSWORD=strong_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.cdc.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

FRONTEND_URL=https://tracer.cdc.example.com
CORS_ALLOWED_ORIGINS=https://tracer.cdc.example.com

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer_user
MAIL_PASSWORD=mailer_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@cdc.example.com
MAIL_FROM_NAME="Tracer CDC"

BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@cdc.example.com
BREVO_SENDER_NAME="Tracer Study"
BREVO_REPLY_TO_EMAIL=support@cdc.example.com
BREVO_REPLY_TO_NAME="CDC Support"
