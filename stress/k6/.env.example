# Wajib salah satu:
# TOKEN=...
# atau LOGIN_EMAIL + LOGIN_PASSWORD
TOKEN=
LOGIN_EMAIL=
LOGIN_PASSWORD=

# Base API
BASE_URL=http://127.0.0.1:8000
API_PREFIX=/api
LOGIN_ENDPOINT_PATH=/login
REQUEST_TIMEOUT=30s

# Endpoint summary filter
SUMMARY_ENDPOINT_PATH=/dashboard/tracer/accreditation-summary
ACCREDITATION_YEAR=2026
TS_LABELS=TS-1,TS-2
FAKULTAS_LIST=
PRODI_LIST=

# Endpoint responses
QID=
RESPONSES_PAGE_MAX=10
RESPONSES_PER_PAGE=50

# Distribusi trafik mix
SUMMARY_WEIGHT=0.7
RESPONSES_WEIGHT=0.25
EXPORT_WEIGHT=0.05
ENABLE_EXPORT=0
EXPORT_FORMAT=xlsx

# Think time
THINK_TIME_MIN=0.2
THINK_TIME_MAX=1.2

# Smoke
SMOKE_VUS=20
SMOKE_DURATION=1m

# Baseline
BASELINE_STAGE1_VUS=200
BASELINE_STAGE2_VUS=500
BASELINE_STAGE1_DURATION=2m
BASELINE_STAGE2_DURATION=5m
BASELINE_RAMPDOWN_DURATION=2m

# Stress
STRESS_STAGE1_VUS=1000
STRESS_STAGE2_VUS=3000
STRESS_STAGE3_VUS=5000
STRESS_STAGE1_DURATION=3m
STRESS_STAGE2_DURATION=5m
STRESS_STAGE3_DURATION=5m
STRESS_RAMPDOWN_DURATION=3m

# Soak
SOAK_VUS=1000
SOAK_DURATION=45m
